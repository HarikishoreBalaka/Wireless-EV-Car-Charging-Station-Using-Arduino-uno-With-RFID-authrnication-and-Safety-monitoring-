#include <SPI.h>
#include <MFRC522.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

#define SS_PIN D4
#define RST_PIN D3
#define RELAY D1
#define IR_PIN D2

MFRC522 rfid(SS_PIN, RST_PIN);
LiquidCrystal_I2C lcd(0x27, 16, 2);

// Valid RFID Card UID
byte validCard[4] = {0xDC, 0xAA, 0xD4, 0x05};

void setup() {

  Serial.begin(9600);

  SPI.begin();
  rfid.PCD_Init();

  pinMode(RELAY, OUTPUT);
  pinMode(IR_PIN, INPUT);

  digitalWrite(RELAY, LOW);

  lcd.init();
  lcd.backlight();

  lcd.setCursor(0, 0);
  lcd.print("System Ready");

  delay(2000);

  lcd.clear();
  lcd.print("Scan Card");
}

void loop() {

  // IR Sensor Check
  if (digitalRead(IR_PIN) == LOW) {

    Serial.println("Obstacle Detected!");

    lcd.clear();
    lcd.print("Obstacle!");

    digitalWrite(RELAY, LOW);

    delay(1000);

    lcd.clear();
    lcd.print("Scan Card");
  }

  // RFID Card Detection
  if (!rfid.PICC_IsNewCardPresent())
    return;

  if (!rfid.PICC_ReadCardSerial())
    return;

  Serial.print("UID: ");

  for (byte i = 0; i < rfid.uid.size; i++) {

    Serial.print(rfid.uid.uidByte[i], HEX);
    Serial.print(" ");
  }

  Serial.println();

  // Check Authorized Card
  if (checkCard(rfid.uid.uidByte)) {

    Serial.println("Access Granted");

    lcd.clear();
    lcd.print("Access Granted");

    digitalWrite(RELAY, HIGH); // Relay ON

  } else {

    Serial.println("Access Denied");

    lcd.clear();
    lcd.print("Access Denied");

    digitalWrite(RELAY, LOW); // Relay OFF
  }

  delay(2000);

  lcd.clear();
  lcd.print("Scan Card");
}

// Function to Verify RFID Card
bool checkCard(byte *uid) {

  for (byte i = 0; i < 4; i++) {

    if (uid[i] != validCard[i]) {

      return false;
    }
  }

  return true;
}
